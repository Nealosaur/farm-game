; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="farm-rpg"
run/main_scene="res://scenes/main/title.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
Clock="*res://scripts/autoload/clock.gd"
GameState="*res://scripts/autoload/game_state.gd"
ItemDB="*res://scripts/autoload/item_db.gd"
Inventory="*res://scripts/autoload/inventory.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
Relationships="*res://scripts/autoload/relationships.gd"
SceneChanger="*res://scripts/autoload/scene_changer.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

